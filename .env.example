# === OpenAI（Agent A，用于生成虚拟受访者的真实反馈与打分）===
OPENAI_API_KEY=sk-your-openai-key
# 使用代理时填写（如 Veee 全局模式），例如：http://127.0.0.1:15236（OpenAI 与 Gemini 共用，也可单独设 GEMINI_PROXY）
OPENAI_PROXY=

# === Google Gemini（Agent B，用于审计 Agent A 的反馈是否像真人、符合 persona）===
GEMINI_API_KEY=your-gemini-api-key

# === Supabase（用于存储分析记录与图片）===
# 在 Supabase 项目 Settings -> API 中可以找到 URL 和 Service Role Key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage：需在 Supabase 控制台 -> Storage 中新建 bucket，名称与此处一致（如 designs），并设为 Public
SUPABASE_STORAGE_BUCKET=designs

# === 访问控制（可选）===
# 设置后，未解锁时只能浏览页面，无法调用 API 生成报告；不设置则无需密码即可分析
UNLOCK_PASSWORD=

